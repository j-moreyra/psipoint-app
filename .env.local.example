# Supabase — fill these in once the project is provisioned.
# Get them from Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DO NOT put SUPABASE_SERVICE_ROLE_KEY in this file. The seed script
# reads it from .env.seed (gated separately); an empty line here would
# count as "set" in the dotenv loader and block .env.seed from
# providing the real value. See HANDOFF.md § Lessons learned (Phase 2).

# Resend — used for transactional email (cert send).
# RESEND_API_KEY: get from https://resend.com/api-keys
# RESEND_FROM_EMAIL: format `Display Name <verified@yourdomain.com>`.
# The domain in the From address must be verified in the Resend
# dashboard or the send will fail with a 403.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
